services:
  portainer:
    image: {{ portainer_server_image }}
    container_name: portainer
    restart: unless-stopped
    command:
      - "--tlscert"
      - "/certs/portainer.crt"
      - "--tlskey"
      - "/certs/portainer.key"
    security_opt:
      - no-new-privileges:true
    volumes:
      - portainer_data:/data
      - {{ app_base_dir }}/portainer_certs:/certs:ro
    networks:
      - public_net
    ports:
      # SEGURIDAD: Bind SOLO a la IP de Tailscale (VPN)
      # No exponer a 0.0.0.0
      - "{{ tailscale_ip }}:9443:9443"
      - "{{ tailscale_ip }}:8000:8000"
    labels:
      com.docker.stack.namespace: "management"
    deploy:
      resources:
        limits:
          cpus: "2.0"
          memory: "2G"
        reservations:
          cpus: "1.0"
          memory: "1G"

networks:
  public_net:
    external: true

volumes:
  portainer_data:
    name: portainer_data
    external: true