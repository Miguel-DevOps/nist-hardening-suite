# Example Caddyfile template for stack_ingress role
# Replace this content with your real configuration.

{
    # SC-7 | Admin API restricted to localhost only (never exposed publicly)
    admin localhost:2019

    email {{ caddy_acme_email | default('admin@example.com') }}
    order coraza_waf first
    order rate_limit before basicauth

    # AU-12/SI-4 | Structured JSON access logs to /var/log/caddy (CrowdSec + AuditD)
    log {
        output file /var/log/caddy/access.log {
            roll_size 100mb
            roll_keep 5
            roll_keep_for 720h
        }
        format json
    }

    # 🛡️ CLOUDFLARE REAL IP RESTORATION
    servers {
        trusted_proxies static {
            173.245.48.0/20
            103.21.244.0/22
            103.22.200.0/22
            103.31.4.0/22
            141.101.64.0/18
            108.162.192.0/18
            190.93.240.0/20
            188.114.96.0/20
            197.234.240.0/22
            198.41.128.0/17
            162.158.0.0/15
            104.16.0.0/13
            104.24.0.0/14
            172.64.0.0/13
            131.0.72.0/22
        }
    }
}

# Health check interno
:2020 {
    respond "OK" 200
}

# 🧱 WAF BLOCK (Coraza)
(waf) {
    coraza_waf {
        directives `
            Include /etc/caddy/coraza.conf
            Include /etc/caddy/owasp-crs/crs-setup.conf
            Include /etc/caddy/owasp-crs/rules/*.conf
            SecRuleEngine DetectionOnly

            SecAuditEngine RelevantOnly
            SecAuditLog /dev/stdout
            SecAuditLogFormat JSON
            SecAuditLogParts ABCDEFGHIJKZ
        `
    }
}

# 🔒 VPN RESTRICTION BLOCK (Zero Trust)
(vpn_only) {
    @denied_vpn {
        not remote_ip {{ tailscale_subnet }} 127.0.0.1/8 ::1
    }
    abort @denied_vpn
}

# -----------------------------------------------------------------------------
# OPTIONAL APP ANNEX EXAMPLE: UPTIME KUMA (uptime-kuma:3001 on public_net)
# Use one mode per app domain according to your risk model.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# 1) RECOMMENDED: VPN-ONLY (Zero Trust, private operations)
# Access limited to Tailscale subnet.
# -----------------------------------------------------------------------------
vpn.example.com {
    import waf
    import vpn_only

    reverse_proxy uptime-kuma:3001 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-For {remote_host}
    }

    tls {
        protocols tls1.2 tls1.3
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}

# -----------------------------------------------------------------------------
# 2) INSECURE EXAMPLE (ANTI-PATTERN): GLOBAL OPEN ACCESS
# DO NOT USE IN PRODUCTION. Any source that can reach this host can reach app.
# -----------------------------------------------------------------------------
unsafe.example.com {
    reverse_proxy uptime-kuma:3001 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-For {remote_host}
    }
}

# -----------------------------------------------------------------------------
# 3) GLOBAL BUT HARDENED: INTERNET ACCESS + WAF + TLS HARDENING
# Use when public exposure is required and controls must stay enforced.
# -----------------------------------------------------------------------------
secure.example.com {
    import waf

    reverse_proxy uptime-kuma:3001 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-For {remote_host}
    }

    tls {
        protocols tls1.2 tls1.3
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}