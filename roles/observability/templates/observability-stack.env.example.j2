# Portainer stack .env example for observability.
# Copy values into Portainer's environment editor when deploying the stack.

GRAFANA_USER=admin@example.com
GRAFANA_PASSWORD=CHANGE_ME_STRONG_PASSWORD
GRAFANA_ROOT_URL=https://grafana.domain.example
HOST_IP={{ observability_stack_host_ip }}
VICTORIA_PORT={{ observability_stack_victoria_port }}
LOKI_PORT={{ observability_stack_loki_port }}
GRAFANA_PORT={{ observability_stack_grafana_port }}
