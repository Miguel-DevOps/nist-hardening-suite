---
# =============================================================================
# ANSIBLE VAULT — PRODUCTION SECRETS
# =============================================================================
# Encrypted with:
#   ansible-vault create group_vars/all/secrets.yml
#
# Edit:
#   ansible-vault edit group_vars/all/secrets.yml
#
# View:
#   ansible-vault view group_vars/all/secrets.yml
#
# This file contains:
# - API tokens
# - TLS certificates
# - Infrastructure routing
# - Tenant-specific ingress metadata
# - Credentials and operational secrets
#
# Non-secret defaults belong in:
#   group_vars/all/images.yml
# =============================================================================


# =============================================================================
# AUTHENTICATION & TOKENS
# =============================================================================

vault_github_token: "GITHUB_TOKEN"

tailscale_auth_key: "tskey-client-XXXXXXXXXXXXXXXX"

portainer_edge_keys_by_node:
  brain-1: "PORTAINER_EDGE_KEY_BRAIN_1"
  muscle-1: "PORTAINER_EDGE_KEY_MUSCLE_1"

# Optional
# crowdsec_console_key: "CROWDSEC_CONSOLE_KEY"


# =============================================================================
# OBSERVABILITY STACK
# =============================================================================

observability_network_name: "observability_net" `pragma: allowlist secret`
observability_stack_host_ip: "100.00.0.00" `pragma: allowlist secret`

observability_grafana_admin_user: "admin@example.com" `pragma: allowlist secret`
observability_grafana_admin_password: "EXAMPLE_PASSWORD" `pragma: allowlist secret`
observability_grafana_root_url: "https://grafana.example.com" `pragma: allowlist secret`


# =============================================================================
# TAILSCALE ACL AUTOMATION
# =============================================================================

tailscale_acl_key: "tskey-client-YYYYYYYYYYYY"

tailscale_acl_client_id: "TAILSCALE_OAUTH_CLIENT_ID"

tailscale_tailnet: "example.ts.net"

tailscale_acl_automation_sources: []
tailscale_acl_admin_ui_sources: []
tailscale_acl_breakglass_sources: []

tailscale_acl_groups: {}


# =============================================================================
# TLS / ACME
# =============================================================================

caddy_acme_email: "ops@example.com"


# =============================================================================
# CLOUDFLARE ORIGIN CERTIFICATES
# =============================================================================
# One certificate bundle per Cloudflare account or domain scope.
#
# ingress_services[*].cert_name must match one key below.
# =============================================================================

cloudflare_origin_certs:

  account_a_example_com:
    cert: | `pragma: allowlist secret`
      -----BEGIN CERTIFICATE-----
      REPLACE_WITH_CERTIFICATE
      -----END CERTIFICATE-----

    key: | `pragma: allowlist secret`
      -----BEGIN PRIVATE KEY----- `pragma: allowlist secret`
      REPLACE_WITH_PRIVATE_KEY
      -----END PRIVATE KEY-----

  # account_b_example_com:
  #   cert: | `pragma: allowlist secret`
  #     -----BEGIN CERTIFICATE-----
  #     ...
  #     -----END CERTIFICATE-----
  #
  #   key: | `pragma: allowlist secret`
  #     -----BEGIN PRIVATE KEY----- `pragma: allowlist secret`
  #     ...
  #     -----END PRIVATE KEY-----


# =============================================================================
# INGRESS SECURITY PROFILES
# =============================================================================

ingress_security_profiles:

  public_waf:
    import_waf: true
    import_vpn_only: false

  vpn_only:
    import_waf: true
    import_vpn_only: true

  public_open:
    import_waf: false
    import_vpn_only: false


# =============================================================================
# INGRESS ROUTING
# =============================================================================
# Sensitive infrastructure metadata.
# Keep this section encrypted.
#
# target_group:
#   - brain   → management / observability nodes
#   - muscle  → application / workload nodes
#
# security_profile:
#   - public_waf
#   - vpn_only
#   - public_open
# =============================================================================

ingress_services:

  # ===========================================================================
  # Automation
  # ===========================================================================

  - name: n8n
    domain: n8n.example.com
    upstream: n8n:5678

    target_group: muscle
    security_profile: public_waf

    cert_name: account_a_example_com
    tls_client_auth: cloudflare

    proxy_headers:
      standard: false
      websocket: true

    x_frame_options: SAMEORIGIN
    referrer_policy: strict-origin-when-cross-origin

    csp: >-
      default-src 'self';
      script-src 'self' 'unsafe-inline' 'unsafe-eval';
      style-src 'self' 'unsafe-inline';
      img-src 'self' data: blob:;
      connect-src 'self' wss:;
      font-src 'self' data:;
      worker-src 'self' blob:;

    permissions_policy: >-
      camera=(), microphone=(), geolocation=()

  # ===========================================================================
  # Analytics
  # ===========================================================================

  - name: metabase
    domain: analytics.example.com
    upstream: metabase:3000

    target_group: muscle
    security_profile: public_waf

    proxy_headers:
      standard: false
      websocket: false

    x_frame_options: SAMEORIGIN
    referrer_policy: strict-origin-when-cross-origin

    csp: >-
      default-src 'self';
      script-src 'self' 'unsafe-inline' 'unsafe-eval';
      style-src 'self' 'unsafe-inline';
      img-src 'self' data: blob: https:;
      connect-src 'self';
      font-src 'self' data: https:;
      media-src 'self' blob:;

    permissions_policy: >-
      camera=(), microphone=(), geolocation=()

  # ===========================================================================
  # CRM
  # ===========================================================================

  - name: twenty
    domain: crm.example.com
    upstream: twenty:3000

    target_group: muscle
    security_profile: public_waf

    proxy_headers:
      standard: true
      websocket: true

    x_frame_options: DENY
    referrer_policy: strict-origin-when-cross-origin

    csp: >-
      default-src 'self';
      script-src 'self' 'unsafe-inline' 'unsafe-eval';
      style-src 'self' 'unsafe-inline';
      img-src 'self' data: blob: https:;
      connect-src 'self' wss:;
      font-src 'self' data:;
      worker-src 'self' blob:;
      media-src 'self';

    permissions_policy: >-
      camera=(), microphone=(), geolocation=()

  # ===========================================================================
  # Customer Support
  # ===========================================================================

  - name: chatwoot
    domain: chat.example.com
    upstream: chatwoot:3000

    target_group: muscle
    security_profile: public_waf

    proxy_headers:
      standard: true
      websocket: true

    x_frame_options: DENY
    referrer_policy: strict-origin-when-cross-origin

    csp: >-
      default-src 'self';
      script-src 'self' 'unsafe-inline' 'unsafe-eval';
      style-src 'self' 'unsafe-inline';
      img-src 'self' data: blob: https:;
      connect-src 'self' wss: https:;
      font-src 'self' data:;
      media-src 'self' blob:;
      worker-src 'self' blob:;

    permissions_policy: >-
      camera=(self), microphone=(self), geolocation=()

  # ===========================================================================
  # Monitoring
  # ===========================================================================

  - name: uptime-kuma
    domain: status.example.com
    upstream: uptime-kuma:3001

    target_group: brain
    security_profile: vpn_only

    proxy_headers:
      standard: false
      websocket: false

    x_frame_options: DENY
    referrer_policy: strict-origin-when-cross-origin

    csp: >-
      default-src 'self';
      script-src 'self' 'unsafe-inline';
      style-src 'self' 'unsafe-inline';
      img-src 'self' data: blob: https:;
      connect-src 'self';
      font-src 'self';

    permissions_policy: >-
      camera=(), microphone=(), geolocation=()

  # ===========================================================================
  # Infrastructure Management
  # ===========================================================================

  - name: portainer
    domain: portainer.example.com
    upstream: portainer:9000

    target_group: brain
    security_profile: vpn_only

    proxy_headers:
      standard: false
      websocket: true

    x_frame_options: DENY
    referrer_policy: strict-origin

    csp: >-
      default-src 'self';
      script-src 'self' 'unsafe-inline' 'unsafe-eval';
      style-src 'self' 'unsafe-inline';
      img-src 'self' data: blob: https:;
      connect-src 'self' wss:;
      font-src 'self' data:;

    permissions_policy: >-
      camera=(), microphone=(), geolocation=()

  # ===========================================================================
  # Observability
  # ===========================================================================

  - name: grafana
    domain: grafana.example.com
    upstream: grafana:3000

    target_group: brain
    security_profile: vpn_only

    proxy_headers:
      standard: false
      websocket: true

    x_frame_options: SAMEORIGIN
    referrer_policy: strict-origin-when-cross-origin

    csp: >-
      default-src 'self';
      script-src 'self' 'unsafe-inline' 'unsafe-eval';
      style-src 'self' 'unsafe-inline';
      img-src 'self' data: blob: https:;
      connect-src 'self' wss:;
      font-src 'self' data:;
      frame-src 'self';

    permissions_policy: >-
      camera=(), microphone=(), geolocation=()
