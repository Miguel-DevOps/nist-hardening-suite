---
# =============================================================================
# ANSIBLE VAULT - ENCRYPTED SECRETS & TENANT-SPECIFIC SENSITIVE DATA
# =============================================================================
# To create this file:
#   ansible-vault create group_vars/all/secrets.yml
#
# To edit:
#   ansible-vault edit group_vars/all/secrets.yml
#
# To view:
#   ansible-vault view group_vars/all/secrets.yml
#
# Keep image tags, package pinning, and general non-secret defaults in:
#   group_vars/all/images.yml
# =============================================================================


# =============================================================================
# AUTHENTICATION & API TOKENS
# =============================================================================

# --- GITHUB TOKEN (Required for Docker Image Pull & Validation) ---
# Generate at: https://github.com/settings/tokens
# Scopes needed:
#   - repo (if using private repos)
#   - read:packages (for GitHub Container Registry)
# Used for:
#   - Pulling custom images: ghcr.io/your-org/imagename:tag
#   - Repository validation
vault_github_token: "GITHUB_TOKEN_GOES_HERE"

# --- TAILSCALE AUTH SECRET (Required for VPN node enrollment) ---
tailscale_auth_key: "tskey-client-XXXXXXXXXXXXXXXX"

# --- PORTAINER EDGE AGENT KEY (Required for Edge Agent deployment) ---
# Generate in Portainer UI: Environments → Add environment → Edge Agent
# This token allows Edge Agents to connect to Portainer server
portainer_edge_key: "PORTAINER_EDGE_KEY_GOES_HERE"

# --- CROWDSEC CONSOLE KEY (Optional - for hybrid signal sharing) ---
# Generate at: https://app.crowdsec.net/
# Used for:
#   - Hybrid signal sharing between OCI and Hetzner nodes
#   - Centralized threat intelligence
# Note: Optional - leave undefined for local-only detection
# crowdsec_console_key: "CROWDSEC_CONSOLE_KEY_GOES_HERE"

# =============================================================================
# TAILSCALE POLICY & TENANT IDENTITY DATA
# =============================================================================

# --- TAILSCALE ACL CREDENTIALS (Optional - for automated ACL management) ---
# OAuth is mandatory in this repository for ACL automation.
# Required scopes for new credentials:
#   - policy_file
#   - devices:core:read
#   - devices:posture_attributes
# Legacy equivalent: acl
# Note: Optional overall. Leave undefined to skip automated ACL configuration.
# Use the OAuth client intended for ACL policy API management (e.g., "Nist Hardening Suite - ACL Config").
# For ACL API, both client secret and client ID are required.
tailscale_acl_key: "tskey-client-YYYYYYYYYYYYYYYY"
tailscale_acl_client_id: "YOUR_TAILSCALE_OAUTH_CLIENT_ID"
tailscale_tailnet: "your-tailscale-tailnet.example.com"  # Optional; API calls default to '-' when omitted


# --- TAILSCALE ACL OPERATORS (Recommended - keep real identities encrypted) ---
# Define least-privilege identities for automation, admin UI, and break-glass access.
# Example:
# tailscale_acl_automation_sources:
#   - "group:platform-automation"
# tailscale_acl_admin_ui_sources:
#   - "group:platform-admins"
# tailscale_acl_breakglass_sources:
#   - "group:breakglass-admins"
# tailscale_acl_groups:
#   group:platform-automation:
#     - "ci-bot@example.com"
#   group:platform-admins:
#     - "alice@example.com"
#   group:breakglass-admins:
#     - "security-oncall@example.com"
tailscale_acl_automation_sources: []
tailscale_acl_admin_ui_sources: []
tailscale_acl_breakglass_sources: []
tailscale_acl_groups: {}

# =============================================================================
# TLS / ACME METADATA
# =============================================================================

# --- CADDY ACME / TLS ---
# Email used for Let's Encrypt / ZeroSSL certificate notifications.
# Required for Caddy to register an ACME account and receive expiry warnings.
caddy_acme_email: "ops@example.com"