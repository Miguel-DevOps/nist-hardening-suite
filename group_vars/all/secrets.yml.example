---
# =============================================================================
# ANSIBLE VAULT - ENCRYPTED SECRETS & TENANT-SPECIFIC SENSITIVE DATA
# =============================================================================
# To create this file:
#   ansible-vault create group_vars/all/secrets.yml
#
# To edit:
#   ansible-vault edit group_vars/all/secrets.yml
#
# To view:
#   ansible-vault view group_vars/all/secrets.yml
#
# Keep image tags, package pinning, and general non-secret defaults in:
#   group_vars/all/images.yml
# =============================================================================


# =============================================================================
# AUTHENTICATION & API TOKENS
# =============================================================================

# --- GITHUB TOKEN (Required for Docker Image Pull & Validation) ---
# Generate at: https://github.com/settings/tokens
# Scopes needed:
#   - repo (if using private repos)
#   - read:packages (for GitHub Container Registry)
# Used for:
#   - Pulling custom images: ghcr.io/your-org/imagename:tag
#   - Repository validation
vault_github_token: "GITHUB_TOKEN_GOES_HERE"

# --- TAILSCALE AUTH SECRET (Required for VPN node enrollment) ---
tailscale_auth_key: "tskey-client-XXXXXXXXXXXXXXXX"

# --- PORTAINER EDGE AGENT KEYS (Required for Edge Agent deployment) ---
# Generate in Portainer UI: Environments → Add environment → Edge Agent
# One key per Edge environment (node), keyed by exact inventory hostname.
# Recommended naming from day one: brain-1, muscle-1, brain-2, muscle-2, ...
portainer_edge_keys_by_node:
  brain-1: "PORTAINER_EDGE_KEY_FOR_BRAIN_1"
  muscle-1: "PORTAINER_EDGE_KEY_FOR_MUSCLE_1"
  # brain-2: "PORTAINER_EDGE_KEY_FOR_BRAIN_2"
  # muscle-2: "PORTAINER_EDGE_KEY_FOR_MUSCLE_2"

# --- CROWDSEC CONSOLE KEY (Optional - for hybrid signal sharing) ---
# Generate at: https://app.crowdsec.net/
# Used for:
#   - Hybrid signal sharing between OCI and Hetzner nodes
#   - Centralized threat intelligence
# Note: Optional - leave undefined for local-only detection
# crowdsec_console_key: "CROWDSEC_CONSOLE_KEY_GOES_HERE"

# --- OBSERVABILITY STACK (Required when enable_observability_stack=true) ---
# Tenant-specific runtime values rendered into /srv/app/observability/.env
# with mode 0600 and consumed by the automated Docker Compose deployment.
# Keep these in Vault because they expose tenant topology and bind addresses.
observability_network_name: "observability_net"
observability_stack_host_ip: "100.64.0.10"
observability_grafana_admin_user: "admin@example.com"
observability_grafana_admin_password: "CHANGE_ME_STRONG_PASSWORD"
observability_grafana_root_url: "https://grafana.domain.example"

# =============================================================================
# TAILSCALE POLICY & TENANT IDENTITY DATA
# =============================================================================

# --- TAILSCALE ACL CREDENTIALS (Optional - for automated ACL management) ---
# OAuth is mandatory in this repository for ACL automation.
# Required scopes for new credentials:
#   - policy_file
#   - devices:core:read
#   - devices:posture_attributes
# Legacy equivalent: acl
# Note: Optional overall. Leave undefined to skip automated ACL configuration.
# Use the OAuth client intended for ACL policy API management (e.g., "Nist Hardening Suite - ACL Config").
# For ACL API, both client secret and client ID are required.
tailscale_acl_key: "tskey-client-YYYYYYYYYYYYYYYY"
tailscale_acl_client_id: "YOUR_TAILSCALE_OAUTH_CLIENT_ID"
tailscale_tailnet: "your-tailscale-tailnet.example.com"  # Optional; API calls default to '-' when omitted


# --- TAILSCALE ACL OPERATORS (Recommended - keep real identities encrypted) ---
# Define least-privilege identities for automation, admin UI, and break-glass access.
# Example:
# tailscale_acl_automation_sources:
#   - "group:platform-automation"
# tailscale_acl_admin_ui_sources:
#   - "group:platform-admins"
# tailscale_acl_breakglass_sources:
#   - "group:breakglass-admins"
# tailscale_acl_groups:
#   group:platform-automation:
#     - "ci-bot@example.com"
#   group:platform-admins:
#     - "alice@example.com"
#   group:breakglass-admins:
#     - "security-oncall@example.com"
tailscale_acl_automation_sources: []
tailscale_acl_admin_ui_sources: []
tailscale_acl_breakglass_sources: []
tailscale_acl_groups: {}

# =============================================================================
# TLS / ACME METADATA
# =============================================================================

# --- CADDY ACME / TLS ---
# Email used for Let's Encrypt / ZeroSSL certificate notifications.
# Required for Caddy to register an ACME account and receive expiry warnings.
caddy_acme_email: "ops@example.com"


# =============================================================================
# INGRESS ROUTING & SECURITY POLICIES (⚠️ TENANT-SPECIFIC & SENSITIVE)
# =============================================================================
# These variables contain sensitive infrastructure information:
#   - Domain names specific to your deployment
#   - Internal service endpoints (upstream targets)
#   - Security policies and CSP headers
#   - WebSocket routing flags
#
# They MUST be encrypted in ansible-vault and moved from group_vars/all/ingress.yml
# to override that unencrypted file.
#
# MIGRATION WORKFLOW:
#   1. Edit this file: ansible-vault edit group_vars/all/secrets.yml
#   2. Copy the ingress_security_profiles and ingress_services sections below
#   3. Customize for your deployment (domains, upstreams, CSPs)
#   4. Once verified, delete group_vars/all/ingress.yml manually
#   5. The Caddyfile will render from encrypted secrets instead
#
# Reference: roles/stack_ingress/templates/Caddyfile.j2
# =============================================================================

# --- INGRESS SECURITY PROFILES ---
# Define WAF and Zero Trust policies applied to ingress routes.
# Profiles are referenced by name in ingress_services entries.
ingress_security_profiles:
  # public_waf: Internet-facing with Coraza WAF protection
  public_waf:
    import_waf: true          # Enable Coraza WAF inspection
    import_vpn_only: false    # Allow public internet access

  # vpn_only: Restricted to Tailscale VPN + WAF protection
  vpn_only:
    import_waf: true          # Enable Coraza WAF inspection
    import_vpn_only: true     # Restrict to Tailscale subnet only

  # public_open: Internet-facing without WAF (use sparingly, only for health checks / APIs)
  public_open:
    import_waf: false         # NO WAF protection
    import_vpn_only: false    # Allow public internet access


# --- INGRESS SERVICES ROUTING CATALOG ---
# Dynamic reverse proxy routes rendered by roles/stack_ingress/templates/Caddyfile.j2
# Each entry produces one Caddy site block with domain, security headers, and routing logic.
#
# Fields:
#   name              – Service identifier (internal use, for debugging/logging)
#   domain            – FQDN for Let's Encrypt TLS + reverse proxy matching
#   upstream          – Docker service endpoint (container:port)
#   security_profile  – Profile name: public_waf | vpn_only | public_open
#   proxy_headers     – Flag settings for header forwarding and WebSocket bypass
#     standard        – Add Host: and X-Real-IP: upstream headers (X-Forwarded-* automatic)
#     websocket       – Bypass Coraza WAF for WebSocket upgrade requests (HTTP still inspected)
#   x_frame_options   – Clickjacking protection: DENY | SAMEORIGIN
#   referrer_policy   – Referrer-Policy header value
#   csp               – Content-Security-Policy header (FULL VALUE, not appended)
#   permissions_policy – Permissions-Policy header (camera, microphone, geolocation, etc.)

ingress_services:
  # =========================================================================
  # AUTOMATION & WORKFLOW
  # =========================================================================
  - name: n8n-automation
    domain: n8n.example.com
    upstream: n8n:5678
    security_profile: public_waf
    proxy_headers:
      standard: false         # n8n handles headers internally
      websocket: true         # n8n editor uses WS for live updates
    x_frame_options: SAMEORIGIN
    referrer_policy: strict-origin-when-cross-origin
    csp: "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' wss:; font-src 'self' data:; worker-src 'self' blob:"
    permissions_policy: "camera=(), microphone=(), geolocation=()"

  # =========================================================================
  # BUSINESS INTELLIGENCE & ANALYTICS
  # =========================================================================
  - name: metabase-bi
    domain: analytics.example.com
    upstream: metabase:3000
    security_profile: public_waf
    proxy_headers:
      standard: false         # Metabase uses X-Forwarded-* automatically
      websocket: false        # No WebSocket needed
    x_frame_options: SAMEORIGIN
    referrer_policy: strict-origin-when-cross-origin
    csp: "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self'; font-src 'self' data: https:; media-src 'self' blob:;"
    permissions_policy: "camera=(), microphone=(), geolocation=()"

  # =========================================================================
  # CRM & CUSTOMER MANAGEMENT
  # =========================================================================
  - name: twenty-crm
    domain: crm.example.com
    upstream: twenty:3000
    security_profile: public_waf
    proxy_headers:
      standard: true          # Twenty CRM needs Host for webhooks/callbacks
      websocket: true         # Real-time collaboration uses WebSocket
    x_frame_options: DENY
    referrer_policy: strict-origin-when-cross-origin
    csp: "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self' wss:; font-src 'self' data:; worker-src 'self' blob:; media-src 'self';"
    permissions_policy: "camera=(), microphone=(), geolocation=()"

  - name: chatwoot-chat
    domain: chat.example.com
    upstream: chatwoot:3000
    security_profile: public_waf
    proxy_headers:
      standard: true          # Chatwoot ActionCable needs Host header
      websocket: true         # ActionCable (Rails WS) for real-time messaging
    x_frame_options: DENY
    referrer_policy: strict-origin-when-cross-origin
    csp: "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self' wss: https:; font-src 'self' data:; media-src 'self' blob:; worker-src 'self' blob:;"
    permissions_policy: "camera=(self), microphone=(self), geolocation=()"

  # =========================================================================
  # UPTIME MONITORING (VPN-ONLY RECOMMENDED)
  # =========================================================================
  - name: uptime-kuma-monitor
    domain: status.example.com
    upstream: uptime-kuma:3001
    security_profile: vpn_only        # Restrict to Tailscale VPN only
    proxy_headers:
      standard: false
      websocket: false
    x_frame_options: DENY
    referrer_policy: strict-origin-when-cross-origin
    csp: "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self'; font-src 'self';"
    permissions_policy: "camera=(), microphone=(), geolocation=()"

  # =========================================================================
  # MANAGEMENT UI (VPN-ONLY RECOMMENDED)
  # =========================================================================
  - name: portainer-mgmt
    domain: portainer.example.com
    upstream: portainer:9000
    security_profile: vpn_only        # Restrict to Tailscale VPN only
    proxy_headers:
      standard: false
      websocket: true                 # Portainer terminal/stats use WebSocket
    x_frame_options: DENY
    referrer_policy: strict-origin
    csp: "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self' wss:; font-src 'self' data:;"
    permissions_policy: "camera=(), microphone=(), geolocation=()"

  # =========================================================================
  # OBSERVABILITY & MONITORING DASHBOARDS (VPN-ONLY)
  # =========================================================================
  - name: grafana-dashboards
    domain: grafana.example.com
    upstream: grafana:3000
    security_profile: vpn_only        # Keep dashboards internal
    proxy_headers:
      standard: false
      websocket: true                 # Grafana WebSocket for live dashboards
    x_frame_options: SAMEORIGIN       # Allow iframe for dashboard sharing
    referrer_policy: strict-origin-when-cross-origin
    csp: "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self' wss:; font-src 'self' data:; frame-src 'self';"
    permissions_policy: "camera=(), microphone=(), geolocation=()"

  # =========================================================================
  # CUSTOM EXAMPLE: STRICT (NO INLINE SCRIPTS - FOR PUBLIC APIs)
  # =========================================================================
  # - name: api-strict-csp
  #   domain: api.example.com
  #   upstream: custom-api:8080
  #   security_profile: public_waf
  #   proxy_headers:
  #     standard: false
  #     websocket: false
  #   x_frame_options: DENY
  #   referrer_policy: strict-origin
  #   csp: "default-src 'none'; img-src 'self'; style-src 'self'; font-src 'self'; connect-src 'self' https://api.example.com; frame-ancestors 'none';"
  #   permissions_policy: "camera=(), microphone=(), geolocation=(), payment=()"

  # =========================================================================
  # CUSTOM EXAMPLE: OPEN (FOR INTERNAL DEBUGGING - NOT RECOMMENDED FOR PROD)
  # =========================================================================
  # - name: dev-debug-app
  #   domain: debug.internal.example.com
  #   upstream: debug-app:8000
  #   security_profile: vpn_only
  #   proxy_headers:
  #     standard: true
  #     websocket: true
  #   x_frame_options: SAMEORIGIN
  #   referrer_policy: no-referrer
  #   csp: "default-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src *;"
  #   permissions_policy: "camera=(self), microphone=(self), geolocation=(self)"
