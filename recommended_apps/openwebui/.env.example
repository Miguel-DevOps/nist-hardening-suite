# =========================================================
# Open WebUI - General Configuration
# =========================================================

# Open WebUI image
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:main

# Secret key used for session signing and encryption
# Generate with:
# openssl rand -base64 32
WEBUI_SECRET_KEY=changeme-super-secret-key

# =========================================================
# Ollama Providers
# =========================================================

# Remote Ollama endpoints accessible through Tailscale
# Multiple endpoints can be separated with ';'
#
# Example:
# http://100.x.y.z:11434
# http://100.x.y.z:11434;http://100.x.y.z:11434
OLLAMA_BASE_URLS=http://100.x.y.z:11434

# =========================================================
# OpenAI-Compatible Providers
# =========================================================

# Multiple API endpoints supported using ';'
#
# Example providers:
# - DeepSeek
# - OpenRouter
# - LocalAI
# - LiteLLM
# - vLLM
OPENAI_API_BASE_URLS=https://api.deepseek.com/v1

# Multiple API keys supported using ';'
OPENAI_API_KEYS=sk-your-api-key

# =========================================================
# Retrieval & Embedding Configuration
# =========================================================

# Recommended extraction backend for production deployments
CONTENT_EXTRACTION_ENGINE=tika

# Embedding provider
#
# Supported examples:
# - openai
# - ollama
# - sentence_transformers
RAG_EMBEDDING_ENGINE=openai

# =========================================================
# Architecture Notes
# =========================================================

# This deployment model is intended for:
#
# - Hetzner cloud nodes
# - Oracle ARM environments
# - Remote Ollama inference over Tailscale
# - Hybrid cloud/local AI execution
#
# Typical architecture:
#
# Open WebUI (cloud)
#        |
#        +--> DeepSeek / OpenAI-compatible APIs
#        |
#        +--> Remote Ollama GPU node over Tailscale
#
# This allows secure GPU offloading without exposing Ollama publicly.

# =========================================================
# Security Notes
# =========================================================

# Open WebUI should only be exposed through Caddy
# or another reverse proxy connected to the public network.
#
# Do NOT expose Ollama directly to the internet.
#
# Tailscale is strongly recommended for private inference routing.
#
# Open WebUI internal configuration such as:
# - admin users
# - signup policy
# - task models
# - providers
# can be configured safely from the UI after bootstrap.
