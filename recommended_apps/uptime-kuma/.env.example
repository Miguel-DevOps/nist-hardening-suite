# ----------------------------------------
# Uptime Kuma Configuration
# ----------------------------------------
# Recommended Uptime Kuma env for secure deployments.
# Keep host ports closed by default and publish through Caddy on public_net.

# Docker Image Tag
UPTIME_KUMA_IMAGE=louislam/uptime-kuma:2.0.2

# Persistent data directory (Ensure this path exists on your host system)
UPTIME_KUMA_DATA_DIR=/srv/app/recommended-apps/uptime-kuma/data

# Optional direct host publish for temporary bootstrap only.
# If you enable this in your own compose override, bind to a trusted interface.
# Example (not enabled by default): 100.00.0.00:3001:3001