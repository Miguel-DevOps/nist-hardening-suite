# =========================================================
# Uptime Kuma - General Configuration
# =========================================================

# Docker image tag
UPTIME_KUMA_IMAGE=louislam/uptime-kuma:2.0.2

# =========================================================
# Security Notes
# =========================================================

# Uptime Kuma is intended to be exposed only through
# Caddy or another reverse proxy connected to the public network.

# Do NOT publish ports directly unless performing
# temporary bootstrap or emergency recovery operations.

# Example temporary override (NOT recommended for production):
#
# ports:
#   - "127.0.0.1:3001:3001"

# =========================================================
# Persistence
# =========================================================

# Application data is stored inside:
# /app/data
#
# Persistent named volumes are recommended for production.
#
# Example host bind override if desired:
#
# volumes:
#   - /srv/app/recommended-apps/uptime-kuma/data:/app/data
