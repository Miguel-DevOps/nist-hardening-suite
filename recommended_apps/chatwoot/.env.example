# =========================================================
# Chatwoot - General Configuration
# =========================================================

# Public URL used by Chatwoot
CHATWOOT_FRONTEND_URL=https://chatwoot.example.com

# Generate a long secure value
CHATWOOT_SECRET_KEY_BASE=changeme-super-secret-key

# =========================================================
# PostgreSQL Configuration
# =========================================================

CHATWOOT_DB_NAME=chatwoot_production
CHATWOOT_DB_HOST=chatwoot-db
CHATWOOT_DB_PORT=5432
CHATWOOT_DB_USER=chatwoot
CHATWOOT_DB_PASSWORD=changeme-db-strong

# PostgreSQL image
CHATWOOT_DB_IMAGE=pgvector/pgvector:pg17

# =========================================================
# Valkey / Redis Configuration
# =========================================================

CHATWOOT_REDIS_HOST=chatwoot-valkey
CHATWOOT_REDIS_PORT=6379
CHATWOOT_REDIS_PASSWORD=changeme-valkey-strong

# Valkey image
CHATWOOT_VALKEY_IMAGE=valkey/valkey:9.0.3

# =========================================================
# SMTP Configuration
# =========================================================

MAILER_SENDER_EMAIL=support@example.com

SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=smtp-user
SMTP_PASSWORD=changeme-smtp-password

SMTP_DOMAIN=example.com
SMTP_AUTHENTICATION=login
SMTP_ENABLE_STARTTLS_AUTO=true

# =========================================================
# Docker Images
# =========================================================

CHATWOOT_IMAGE=chatwoot/chatwoot:v4.12.1

# =========================================================
# Security Notes
# =========================================================

# Expose ONLY the Chatwoot frontend service to the public network.
# PostgreSQL and Valkey must remain internal-only.
# Always place Chatwoot behind Caddy or another reverse proxy.
# Never publish database or Redis ports externally.

# =========================================================
# Initial Database Bootstrap
# =========================================================

# Run once after the first deployment:

# docker compose exec chatwoot \
#   bundle exec rails db:chatwoot_prepare
