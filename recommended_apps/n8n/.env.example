# =========================================================
# n8n - General Configuration
# =========================================================
# Public URL used by n8n and webhooks
N8N_HOST=n8n.example.com
N8N_PROTOCOL=https
N8N_EDITOR_BASE_URL=https://n8n.example.com
WEBHOOK_URL=https://n8n.example.com

# Reverse proxy configuration
N8N_PROXY_HOPS=1

# =========================================================
# Security & Authentication
# =========================================================
# Enable basic authentication for the n8n dashboard
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme-strong

# Internal encryption key used by n8n
# IMPORTANT: use a long and secure value in production
N8N_ENCRYPTION_KEY=changeme-strong

# =========================================================
# PostgreSQL Database Configuration
# =========================================================
N8N_DB_TYPE=postgresdb
N8N_DB_POSTGRESDB_HOST=postgres
N8N_DB_POSTGRESDB_PORT=5432
N8N_DB_POSTGRESDB_DATABASE=n8n
N8N_DB_POSTGRESDB_USER=n8n
N8N_DB_POSTGRESDB_PASSWORD=changeme-db

# PostgreSQL Docker image
N8N_DB_IMAGE=postgres:17

# =========================================================
# Queue Mode & Valkey Configuration
# =========================================================
# Run workflow executions using distributed workers
EXECUTIONS_MODE=queue

# Valkey / Redis connection settings
N8N_REDIS_HOST=valkey
N8N_REDIS_PORT=6379
N8N_REDIS_PASSWORD=changeme-valkey-strong

# Allow manual executions to be processed by workers
OFFLOAD_MANUAL_EXECUTIONS_TO_WORKERS=true

# Valkey Docker image
N8N_VALKEY_IMAGE=valkey/valkey:9.0.3

# =========================================================
# Logging & Monitoring
# =========================================================
# Available levels: debug | info | warn | error
N8N_LOG_LEVEL=warn

# Log output format: console | json
N8N_LOG_OUTPUT=json

# =========================================================
# Privacy & Telemetry
# =========================================================
# Disable diagnostics and external notifications
N8N_DIAGNOSTICS_ENABLED=false
N8N_VERSION_NOTIFICATIONS_ENABLED=false
N8N_PERSONALIZATION_ENABLED=false
# =========================================================
# Security Notes
# =========================================================

# Always expose Metabase through Caddy or another reverse proxy.
# Do NOT publish PostgreSQL ports externally.
# Only the Metabase service should join the public network.
