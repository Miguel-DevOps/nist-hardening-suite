# =========================================================
# Metabase - General Configuration
# =========================================================

# Public URL used by Metabase
METABASE_SITE_URL=https://metabase.example.com

# Display name shown inside Metabase
METABASE_SITE_NAME=Metabase

# Java timezone used by the container
METABASE_JAVA_TIMEZONE=UTC

# =========================================================
# PostgreSQL Database Configuration
# =========================================================

METABASE_DB_NAME=metabase
METABASE_DB_HOST=metabase-db
METABASE_DB_PORT=5432
METABASE_DB_USER=metabase
METABASE_DB_PASSWORD=changeme-db-strong

# PostgreSQL Docker image
METABASE_DB_IMAGE=postgres:17-alpine

# =========================================================
# Metabase Application Image
# =========================================================

METABASE_IMAGE=metabase/metabase:v0.59.6.3

# =========================================================
# Performance & Cache
# =========================================================

# Maximum cache size in KB
METABASE_QUERY_CACHING_MAX_KB=2000

# Cache TTL in seconds
METABASE_QUERY_CACHING_MAX_TTL=3024000

# =========================================================
# Privacy & Telemetry
# =========================================================

# Disable anonymous telemetry
METABASE_ANON_TRACKING_ENABLED=false

# Optional embedding origin
METABASE_EMBEDDING_APP_ORIGIN=

# =========================================================
# Security Notes
# =========================================================

# Always expose Metabase through Caddy or another reverse proxy.
# Do NOT publish PostgreSQL ports externally.
# Only the Metabase service should join the public network.
