# ----------------------------------------
# Metabase Configuration
# ----------------------------------------

# Public URL used by Metabase for links and redirects
METABASE_SITE_URL=http://example.com

# Display name for the instance
METABASE_SITE_NAME=Metabase

# Java timezone used by the container
METABASE_JAVA_TIMEZONE=UTC

# Query cache controls (Metabase stores cached results in the application database)
METABASE_QUERY_CACHING_MAX_KB=2000
METABASE_QUERY_CACHING_MAX_TTL=3024000

# Metabase application database credentials
METABASE_DB_NAME=metabase
METABASE_DB_HOST=metabase-db
METABASE_DB_PORT=5432
METABASE_DB_USER=metabase_user
METABASE_DB_PASSWORD=secure-random-db-password

# Docker image tags
METABASE_IMAGE=metabase/metabase:v0.59.6.3
METABASE_DB_IMAGE=postgres:17-alpine
