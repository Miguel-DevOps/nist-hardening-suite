# =========================================================
# Twenty CRM - General Configuration
# =========================================================

# Public URL used by Twenty CRM
TWENTY_SERVER_URL=https://crm.example.com

# Application secret
# IMPORTANT: use a long random secure value
TWENTY_APP_SECRET=changeme-super-secret-key

# =========================================================
# PostgreSQL Configuration
# =========================================================

TWENTY_DB_NAME=twenty
TWENTY_DB_HOST=twenty-db
TWENTY_DB_PORT=5432
TWENTY_DB_USER=twenty
TWENTY_DB_PASSWORD=changeme-db-strong

# PostgreSQL image
TWENTY_DB_IMAGE=postgres:17-alpine

# =========================================================
# Valkey / Redis Configuration
# =========================================================

TWENTY_REDIS_HOST=twenty-valkey
TWENTY_REDIS_PORT=6379
TWENTY_REDIS_PASSWORD=changeme-valkey-strong

# Valkey image
TWENTY_VALKEY_IMAGE=valkey/valkey:9.0.3

# =========================================================
# Docker Images
# =========================================================

TWENTY_IMAGE=twentycrm/twenty:v1.19.0

# =========================================================
# Security Notes
# =========================================================

# Only the Twenty CRM frontend service should join the public network.
# PostgreSQL and Valkey must remain internal-only.
# Always expose Twenty CRM through Caddy or another reverse proxy.
# Never publish database or Redis ports externally.

# =========================================================
# Persistence
# =========================================================

# Twenty CRM stores uploaded assets and application data in:
# /app/storage
#
# Persistent named volumes are strongly recommended for production.
