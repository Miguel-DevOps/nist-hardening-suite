# ----------------------------------------
# Twenty CRM Configuration
# ----------------------------------------

# Base URL
TWENTY_SERVER_URL=http://example.com

# Security
TWENTY_APP_SECRET=secure-random-secret-key

# Database Credentials
TWENTY_DB_USER=twenty_user
TWENTY_DB_PASSWORD=secure-random-db-password

# Valkey (Redis) Credentials
TWENTY_REDIS_PASSWORD=secure-random-redis-password

# Docker Image Tags (Override if needed)
TWENTY_IMAGE=twentycrm/twenty:v1.19.0
TWENTY_DB_IMAGE=postgres:17-alpine
TWENTY_VALKEY_IMAGE=valkey/valkey:9.0.3